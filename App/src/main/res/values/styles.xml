<?xml version="1.0" encoding="utf-8"?>
<resources>

    <!-- 🔹 الثيم الأساسي للتطبيق -->
    <style name="AppTheme" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <!-- ألوان أساسية -->
        <item name="colorPrimary">@color/teal_700</item>
        <item name="colorPrimaryVariant">@color/teal_500</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorSecondary">@color/blue_primary</item>
        <item name="colorSecondaryVariant">@color/blue_light</item>
        <item name="colorOnSecondary">@color/white</item>

        <!-- خلفية عامة -->
        <item name="android:windowBackground">@color/background_light</item>

        <!-- خط افتراضي -->
        <item name="android:fontFamily">@font/arial</item>
    </style>

    <!-- 🔹 ثيم للأزرار -->
    <style name="ButtonStyle" parent="Widget.MaterialComponents.Button">
        <item name="android:textColor">@color/white</item>
        <item name="backgroundTint">@color/teal_700</item>
        <item name="android:padding">12dp</item>
    </style>

    <!-- 🔹 ثيم للنصوص -->
    <style name="TextStyle" parent="TextAppearance.MaterialComponents.Body1">
        <item name="android:textColor">@color/black</item>
        <item name="android:fontFamily">@font/arial</item>
    </style>

</resources>
