<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    package="com.madyan.inventory">

    <!-- 🔹 الصلاحيات -->
    <uses-permission android:name="android.permission.INTERNET"/>
    <uses-permission android:name="android.permission.WRITE_EXTERNAL_STORAGE"/>
    <uses-permission android:name="android.permission.READ_EXTERNAL_STORAGE"/>

    <application
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="تطبيق الجرد المخزني"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.InventoryApp">

        <!-- 🔹 شاشة تسجيل الدخول -->
        <activity android:name=".ui.LoginActivity">
            <intent-filter>
                <action android:name="android.intent.action.MAIN"/>
                <category android:name="android.intent.category.LAUNCHER"/>
            </intent-filter>
        </activity>

        <!-- 🔹 شاشة لوحة التحكم -->
        <activity android:name=".ui.DashboardActivity"/>

        <!-- 🔹 شاشة المنتجات -->
        <activity android:name=".ui.ProductActivity"/>

        <!-- 🔹 شاشة المخازن -->
        <activity android:name=".ui.WarehouseActivity"/>

        <!-- 🔹 شاشة الجرد -->
        <activity android:name=".ui.InventoryActivity"/>

        <!-- 🔹 شاشة التقارير -->
        <activity android:name=".ui.ReportsActivity"/>

    </application>
</manifest>
